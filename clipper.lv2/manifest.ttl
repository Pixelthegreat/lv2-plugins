@prefix lv2:  <http://lv2plug.in/ns/lv2core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ui:   <http://lv2plug.in/ns/extensions/ui#> .

<http://fanfavoritessofar.com/clipper>
	a lv2:Plugin ;
	lv2:binary <clipper.so> ;
	rdfs:seeAlso <clipper.ttl> .

<http://fanfavoritessofar.com/clipper#ui-x11>
	a ui:X11UI ;
	lv2:binary <clipper-ui.so> ;
	rdfs:seeAlso <clipper-ui.ttl> .
